{
  "name": "glory-rs",
  "private": true,
  "description": "Comandos unificados para el monorepo Rust + React",
  "scripts": {
    "dev": "node glory-rs/scripts/dev.mjs",
    "check": "cargo check && cargo clippy && npm --prefix frontend run type-check",
    "check:back": "cargo check && cargo clippy",
    "check:front": "npm --prefix frontend run type-check",
    "fmt": "cargo fmt",
    "fmt:check": "cargo fmt --check",
    "dev:back": "cargo run",
    "dev:front": "npm --prefix frontend run dev",
    "codegen": "npm --prefix frontend run codegen",
    "test": "cargo test"
  }
}
