# Base de datos PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/glory_db

# Secret para firmar tokens JWT — cambiar en producción
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars

# Servidor
HOST=127.0.0.1
PORT=3000

# Logging (trace, debug, info, warn, error)
RUST_LOG=glory_backend=debug,tower_http=debug

# [303A-2] CORS: orígenes permitidos separados por coma. Si no se define, permite todo (dev)
# CORS_ORIGINS=http://restaurante.wandori.us

# [303A-2] Modo demo: habilita endpoints /api/admin/seed y /api/admin/reset
# DEMO_MODE=true

# URL pública del frontend (para enlaces en emails de recuperación)
# APP_URL=http://localhost:5173

# SMTP del servidor (para emails de reset de password y reportes de errores)
# Las credenciales de marketing (SMTP, Twilio, Meta) se configuran por usuario
# desde la interfaz web: Configuración > Integraciones
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASSWORD=tu-app-password
# SMTP_FROM_EMAIL=noreply@restaurante.com
# SMTP_FROM_NAME=Restaurante

# Email para reportes de errores del sistema
# ERROR_REPORT_EMAIL=admin@restaurante.com
