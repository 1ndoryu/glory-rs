# Base de datos PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/glory_db

# Secret para firmar tokens JWT — cambiar en producción
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars

# Servidor
HOST=127.0.0.1
PORT=3000

# Logging (trace, debug, info, warn, error)
RUST_LOG=glory_backend=debug,tower_http=debug

# URLs públicas
PUBLIC_BASE_URL=http://127.0.0.1:3000
WS_PUBLIC_URL=ws://127.0.0.1:3000/api/ws

# Tickets websocket
WS_SECRET=change-this-to-a-different-random-secret-key-at-least-32-chars
WS_TICKET_TTL_SECS=60

# Web Push VAPID (opcionales; si faltan, el canal push queda deshabilitado)
# Compatibles también con KAMPLES_VAPID_PUBLIC_KEY / KAMPLES_VAPID_PRIVATE_KEY / KAMPLES_VAPID_SUBJECT
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=https://kamples.com

# FCM Android (opcional; si falta, el canal Android push queda deshabilitado)
# Compatible también con KAMPLES_FCM_SERVICE_ACCOUNT_JSON
FCM_SERVICE_ACCOUNT_JSON=

# SMTP / email (opcional; si faltan, los correos quedan deshabilitados)
# Compatibles con aliases legacy SMTP_PASS y SMTP_FROM
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=tls
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Kamples
