# Base de datos PostgreSQL
# En desarrollo, `npm run dev` ignora el nombre de BD de `DATABASE_URL` y usa
# una BD aislada por rama/proyecto (`glory-rust-nakomi` -> `nakomi_db`,
# ramas Kamples -> `glory_kamples`). Sobrescribir con `GLORY_DEV_DB_NAME`.
DATABASE_URL=postgres://postgres:password@localhost:5432/glory_db

# Secret para firmar tokens JWT — cambiar en producción
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars

# Servidor
HOST=127.0.0.1
PORT=3000

# Logging (trace, debug, info, warn, error)
RUST_LOG=glory_backend=debug,tower_http=debug

# [084A-37] AI Chatbot — Groq (proveedor primario)
# Hasta 3 keys para rotación round-robin (rate limit 429)
# GROQ_API_1=gsk_...
# GROQ_API_2=gsk_...
# GROQ_API_3=gsk_...
# AI_MODEL=openai/gpt-oss-120b

# [084A-37] AI Chatbot — Google Gemini (proveedor secundario, fallback)
# API OpenAI-compatible. Se usa automáticamente si Groq agota todos los modelos.
# Obtener key en: https://aistudio.google.com/apikey
# GOOGLE_GEMINI_API=AIza...

# [104A-17] Contabo API (opcional, solo para el panel admin de VPS en Hosting)
# Usa el API Password real de Contabo. `PASSWORD_CONTABO` se mantiene solo por compatibilidad legacy.
# CONTABO_CLIENT_ID=
# CONTABO_CLIENT_SECRET=
# CONTABO_API_USER=
# CONTABO_API_PASSWORD=

# [154A-11] Coolify API (provisioning de hostings)
# Obtener desde el panel Coolify: Settings  API Tokens
COOLIFY_BASE_URL=
COOLIFY_API_TOKEN=
COOLIFY_SERVER_UUID=
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_IP=

# [084A-24] Stripe — pagos de pedidos y suscripciones
# GLORY_STRIPE_SECRET_KEY=sk_live_...
# GLORY_STRIPE_WEBHOOK_SECRET=whsec_...
# Hosting y VPS usan `price_data` dinámico; no requieren Price IDs fijos por plan.

# URL pública del frontend (para callbacks de Stripe, etc.)
# GLORY_PUBLIC_URL=https://nakomi.studio

# CORS: orígenes permitidos separados por coma (vacío = allow all en dev)
# GLORY_ALLOWED_ORIGINS=https://nakomi.studio

# [154A-15c] Email SMTP (notificaciones)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@nakomi.studio

# Directorio de archivos estáticos del frontend compilado (producción)
# STATIC_DIR=frontend/dist
