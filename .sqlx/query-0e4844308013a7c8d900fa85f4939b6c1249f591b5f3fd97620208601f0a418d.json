{
  "db_name": "PostgreSQL",
  "query": "SELECT re.id, re.regla_id, rr.nombre AS regla_nombre, re.reserva_id, r.nombre_cliente, r.fecha AS fecha_reserva, r.hora AS hora_reserva, re.canal, re.estado, re.enviado_at, re.error_mensaje FROM recordatorios_enviados re JOIN reglas_recordatorio rr ON rr.id = re.regla_id JOIN reservas r ON r.id = re.reserva_id WHERE rr.user_id = $1 ORDER BY re.enviado_at DESC LIMIT $2 OFFSET $3",
