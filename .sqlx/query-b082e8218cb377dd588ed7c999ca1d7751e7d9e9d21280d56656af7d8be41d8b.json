  "query": "\n            SELECT id, wallet_id, user_id, amount_cents, transaction_type,\n                   reference_type, reference_id, description, balance_after_cents, created_at\n            FROM wallet_transactions\n            WHERE user_id = $1\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
