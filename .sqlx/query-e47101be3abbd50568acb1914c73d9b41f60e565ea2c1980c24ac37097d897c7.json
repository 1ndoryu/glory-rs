  "query": "SELECT\n                id,\n                id_corto as \"id_corto!\",\n                formato as \"formato!\",\n                COALESCE(tags, ARRAY[]::text[]) as \"tags!: Vec<String>\",\n                tipo as \"tipo!\",\n                es_premium as \"es_premium!\",\n                COALESCE(metadata, '{}'::jsonb) as \"metadata!: serde_json::Value\",\n                estado as \"estado!\",\n                ruta_original as \"ruta_original!\"\n             FROM samples\n             WHERE id = $1\n               AND eliminado_en IS NULL\n             LIMIT 1",
