{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                usuario_id AS user_id,\n                plan,\n                estado AS \"status!\",\n                stripe_subscription_id,\n                inicio_at AS start_at,\n                fin_at AS end_at,\n                created_at AS \"created_at!\"\n            FROM suscripciones\n            WHERE usuario_id = $1\n              AND estado IN ('activa', 'periodo_prueba')\n            ORDER BY COALESCE(fin_at, NOW()) DESC, created_at DESC\n            LIMIT 1\n            ",
