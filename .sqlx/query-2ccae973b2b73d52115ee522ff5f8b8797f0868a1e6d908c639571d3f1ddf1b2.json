{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            s.id            AS \"id!\",\n            s.creador_id    AS \"creador_id!\",\n            s.titulo        AS \"titulo!\",\n            s.slug          AS \"slug!\",\n            s.tipo          AS \"tipo!\",\n            s.bpm           AS \"bpm?\",\n            s.key           AS \"key?\",\n            s.escala        AS \"escala?\",\n            s.tags          AS \"tags!\",\n            s.publicado_at  AS \"publicado_at?\",\n            s.total_likes,\n            s.total_reproducciones,\n            s.total_descargas,\n            s.verificado\n        FROM samples s\n        WHERE s.estado = 'activo'\n          AND s.id <> $1\n          AND (s.tags && $2::text[] OR s.tipo = $3)\n          AND s.creador_id <> ALL($4::int[])\n        ORDER BY s.publicado_at DESC NULLS LAST\n        LIMIT $5\n        ",
