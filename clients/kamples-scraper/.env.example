# Kamples Scraper — Variables de entorno
# Copiar a .env y ajustar valores

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kamples
DB_USER=kamples
DB_PASSWORD=

# DataImpulse Proxy (residencial, $1/GB)
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_USER=
PROXY_PASSWORD=

# Presupuesto de proxy en bytes (5 GB = 5368709120)
PROXY_BUDGET_BYTES=5368709120

# Directorio temporal para audio
AUDIO_TMP_DIR=/tmp/kamples_audio

# Imágenes: descarga local (preservación) — wp-content/uploads/kamples/portadas/
# Ajustar la ruta absoluta según entorno (Windows / Linux / AWS)
IMAGES_STORE_PATH=/var/www/html/wp-content/uploads/kamples/portadas
IMAGES_BASE_URL=https://tu-dominio.com/wp-content/uploads/kamples/portadas
