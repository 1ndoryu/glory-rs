# Kamples Scraper — Variables de entorno
# Copiar a .env y ajustar valores
# [274A-1] La BD canonica es glory_kamples (ya no kamples). Las vars KAMPLES_PG_*
# tienen prioridad sobre DB_*; el .env del root del repo tambien aporta defaults.

# PostgreSQL (preferido)
KAMPLES_PG_HOST=127.0.0.1
KAMPLES_PG_PORT=5432
KAMPLES_PG_DBNAME=glory_kamples
KAMPLES_PG_USER=postgres
KAMPLES_PG_PASSWORD=

# Compatibilidad legacy (DB_*) — usado solo si KAMPLES_PG_* no esta definido
DB_HOST=localhost
DB_PORT=5432
DB_NAME=glory_kamples
DB_USER=postgres
DB_PASSWORD=

# DataImpulse Proxy (residencial, $1/GB)
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_USER=
PROXY_PASSWORD=

# Presupuesto de proxy en bytes (5 GB = 5368709120)
PROXY_BUDGET_BYTES=5368709120

# Directorio temporal para audio
AUDIO_TMP_DIR=/tmp/kamples_audio

# Imagenes: descarga local (whosampled bloquea hotlink) — ./uploads/kamples/portadas/
# Windows: usar /, ej C:/Users/.../uploads/kamples/portadas
# Linux:   /var/www/.../uploads/kamples/portadas (WP) o /app/uploads/kamples/portadas (Rust)
IMAGES_STORE_PATH=/absolute/path/to/uploads/kamples/portadas
# IMAGES_BASE_URL puede ser relativa (/uploads/...) si Axum sirve uploads/, o absoluta para WordPress.
IMAGES_BASE_URL=/uploads/kamples/portadas
