{
  "$schema": "https://raw.githubusercontent.com/nicdelhi/tauri2-schema/main/tauri.conf.json",
  "productName": "Kamples",
  "version": "0.1.0",
  "identifier": "app.kamples.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Kamples",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      },
      {
        "label": "sync-panel",
        "title": "Kamples Sync",
        "url": "sync.html",
        "width": 380,
        "height": 520,
        "minWidth": 320,
        "minHeight": 400,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "shadow": false,
        "transparent": true,
        "closable": false
      },
      {
        "label": "config-sync",
        "title": "Configuración",
        "url": "config.html",
        "width": 460,
        "height": 500,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost http://localhost:1420 http://localhost:3000 https://api.kamples.com wss://api.kamples.com ws://localhost:3000 https://*.stripe.com https://accounts.google.com ipc: http://ipc.localhost; img-src 'self' http://localhost:3000 https://api.kamples.com asset: http://asset.localhost data: blob: https:; media-src 'self' http://localhost:3000 https://api.kamples.com asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'unsafe-inline' https://accounts.google.com; frame-src 'self' https://accounts.google.com",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/32x32.png", "icons/favicon.svg"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "scheme": ["kamples"], "host": "auth" }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzMkY4N0I4MjEzRkZCOTcKUldTWCt6OGh1SWN2VTJoblVNQm9vUnVzU0NaVTczQjMvQW1TcTBHNDNOQWVMWDN2ZmZDeUF5RjcK",
      "endpoints": [
        "https://api.kamples.com/api/app/updater/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
