# [174A-115] Plantilla de variables para despliegue Coolify / docker-compose.
#
# Copia este archivo a `.env` en la RAÍZ DEL STACK COOLIFY (no en el repo)
# y rellena los valores. NUNCA commitear `.env` con secrets reales.
#
# Lee `Agente/documentacion/deploy/secrets-2026-04-20.md` para detalles
# sobre cómo gestionar cada secret y rotarlos.

# === REQUERIDOS ===

# Postgres (servicio interno del compose)
POSTGRES_DB=kamples
POSTGRES_USER=kamples
POSTGRES_PASSWORD=cambiame-genera-32-chars-min

# JWT — generar con `openssl rand -base64 48`
JWT_SECRET=cambiame-genera-48-bytes-base64
WS_SECRET=

# URL pública del frontend (la que ven usuarios). Coolify la asigna o
# configura el dominio en su UI; debe coincidir con el dominio Traefik.
PUBLIC_BASE_URL=https://kamples.example.com
WS_PUBLIC_URL=wss://kamples.example.com/api/ws

# === OPCIONALES (se ignoran si vacíos) ===

# Logging y conexiones
RUST_LOG=glory_backend=info,tower_http=info,sqlx=warn
LOG_FORMAT=json
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2

# Storage (default local). S3-compatible (R2/MinIO/AWS) requiere build con
# `--features s3` y rellenar S3_BUCKET/S3_ENDPOINT_URL.
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT_URL=

# Auth Google (CSV de client_ids: web,android,ios)
GOOGLE_CLIENT_IDS=

# Web Push (VAPID — generar con `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@kamples.example.com

# FCM Android (JSON entero del service-account, una sola línea)
FCM_SERVICE_ACCOUNT_JSON=

# SMTP transaccional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=tls
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Kamples

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Scraper Python externo (validación HMAC del header X-Kamples-Secret)
SCRAPER_SECRET=

# Backup automático (sidecar postgres-backup)
BACKUP_INTERVAL_SECONDS=21600   # cada 6 horas
BACKUP_RETENTION_DAYS=14
